{
  "title": "MC-DR Orchestrator",
  "description": "Multi-cloud DR health — GCP primary / Azure standby",
  "uid": "mc-dr-dashboard",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["dr", "gcp", "azure", "kubernetes"],
  "annotations": {
    "list": [
      {
        "name": "Failover events",
        "datasource": { "type": "stackdriver", "uid": "gcp-stackdriver" },
        "expr": "fetch global::custom.googleapis.com/dr/FailoverCompleted | filter value == 1",
        "iconColor": "red",
        "enable": true
      },
      {
        "name": "Failback events",
        "datasource": { "type": "stackdriver", "uid": "gcp-stackdriver" },
        "expr": "fetch global::custom.googleapis.com/dr/FailbackCompleted | filter value == 1",
        "iconColor": "green",
        "enable": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Primary Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "HEALTHY", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "stackdriver", "uid": "gcp-stackdriver" },
          "metricType": "custom.googleapis.com/dr/PrimaryHealthy",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Response Latency (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "stackdriver", "uid": "gcp-stackdriver" },
          "metricType": "custom.googleapis.com/dr/PrimaryLatencyMs",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Consecutive Failures",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "stackdriver", "uid": "gcp-stackdriver" },
          "metricType": "custom.googleapis.com/dr/ConsecutiveFailures",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Last Failover Result",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "SUCCESS", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "FAILED", "color": "red" } } }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "type": "stackdriver", "uid": "gcp-stackdriver" },
          "metricType": "custom.googleapis.com/dr/FailoverCompleted",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Latency Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "stackdriver", "uid": "gcp-stackdriver" },
          "metricType": "custom.googleapis.com/dr/PrimaryLatencyMs",
          "refId": "A",
          "legendFormat": "GKE primary latency"
        }
      ]
    },
    {
      "id": 6,
      "title": "Health Check Status Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "stackdriver", "uid": "gcp-stackdriver" },
          "metricType": "custom.googleapis.com/dr/PrimaryHealthy",
          "refId": "A",
          "legendFormat": "Primary healthy (1=yes 0=no)"
        }
      ]
    },
    {
      "id": 7,
      "title": "Failover / Failback Duration (seconds)",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 600 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "stackdriver", "uid": "gcp-stackdriver" },
          "metricType": "custom.googleapis.com/dr/FailoverDurationSeconds",
          "refId": "A",
          "legendFormat": "Failover duration"
        },
        {
          "datasource": { "type": "stackdriver", "uid": "gcp-stackdriver" },
          "metricType": "custom.googleapis.com/dr/FailbackDurationSeconds",
          "refId": "B",
          "legendFormat": "Failback duration"
        }
      ]
    }
  ]
}
