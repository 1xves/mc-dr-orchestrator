###############################################################################
# Postgres 15 StatefulSet ({{ cloud }} {{ postgres_role }})
# Rendered by Ansible; per-cluster values come from inventory/hosts.yml.
# StorageClass: {{ storage_class }}
# PVC persists when nodes scale to 0; data survives scale cycles.
###############################################################################
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: postgres
  namespace: {{ postgres_namespace }}
  labels:
    app: postgres
    role: {{ postgres_role }}
spec:
  serviceName: postgres
  replicas: {{ postgres_replicas }}
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
        role: {{ postgres_role }}
    spec:
      terminationGracePeriodSeconds: 60
      containers:
        - name: postgres
          image: {{ postgres_image }}
          ports:
            - containerPort: 5432
              name: postgres
          envFrom:
            - secretRef:
                name: postgres-credentials
          env:
            - name: PGDATA
              value: {{ postgres_pgdata }}
          resources:
            requests:
              cpu: "100m"
              memory: "256Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
          volumeMounts:
            - name: postgres-data
              mountPath: /var/lib/postgresql/data
          livenessProbe:
            exec:
              command:
                - pg_isready
                - -U
                - {{ postgres_user }}
            initialDelaySeconds: 30
            periodSeconds: 10
            failureThreshold: 6
          readinessProbe:
            exec:
              command:
                - pg_isready
                - -U
                - {{ postgres_user }}
            initialDelaySeconds: 5
            periodSeconds: 5
  volumeClaimTemplates:
    - metadata:
        name: postgres-data
      spec:
        accessModes: ["ReadWriteOnce"]
        storageClassName: {{ storage_class }}
        resources:
          requests:
            storage: {{ postgres_storage_size }}
