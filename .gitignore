# Terraform secrets — NEVER commit
terraform/*.tfvars
!terraform/*.tfvars.example
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform/
terraform/.terraform.lock.hcl

# Environment files
.env
.env.*
!.env.example

# GCP credentials
*-key.json
*credentials*.json
application_default_credentials.json

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# macOS
.DS_Store
functions/*.zip
